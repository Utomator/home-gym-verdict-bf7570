# Database (Neon)
# On Vercel, DATABASE_URL MUST be the POOLED (-pooler) Neon host. Migrations use
# DATABASE_URL_DIRECT (direct, non-pooled host).
DATABASE_URL=postgres://user:pass@host-pooler/db?sslmode=require
DATABASE_URL_DIRECT=postgres://user:pass@host-direct/db?sslmode=require
# Per-instance pg pool size. Keep low on serverless so many warm instances don't
# exhaust Neon's connection limit (PgBouncer multiplexes). Default 5.
DATABASE_POOL_MAX=5

# Payload
PAYLOAD_SECRET=replace-with-32+char-random

# Public site URL + indexability
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
SITE_INDEXABLE=false

# Media (local filesystem fallback; used only when R2 is NOT configured).
MEDIA_DIR=media

# Media storage: Cloudflare R2 (S3-compatible). Leave R2_BUCKET unset to use the
# local-disk fallback above (local dev / tests). Set all five to enable R2.
# R2_ENDPOINT is the S3 API endpoint (uploads only):
#   https://<accountId>.r2.cloudflarestorage.com
# R2_PUBLIC_URL is the CDN base for SERVING media (the *.r2.dev subdomain or a
# connected custom domain), e.g. https://pub-<hash>.r2.dev
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# Website authoring MCP (POST /mcp/authoring) bearer token. The platform spawn
# handler injects this into the spawned Claude's env; the route is fail-closed
# (returns 401 when unset). Generate a long random secret.
SITE_AUTHORING_TOKEN=

# Webhooks (prod only)
CALENDLY_WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=
CALENDLY_BOOKING_URL=

# IndexNow (prod only)
INDEXNOW_KEY=

# Sentry (prod only)
SENTRY_DSN=

# Logging
LOG_LEVEL=debug
